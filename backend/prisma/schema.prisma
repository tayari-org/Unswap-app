generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                            String    @id @default(uuid())
  email                         String    @unique
  username                      String?   @unique
  password_hash                 String?
  google_id                     String?   @unique
  linkedin_id                   String?   @unique
  x_id                          String?   @unique
  full_name                     String?
  role                          String    @default("user")
  avatar_url                    String?
  phone                         String?
  bio                           String?
  institution                   String?
  organization                  String?
  job_title                     String?
  staff_grade                   String?
  duty_station                 String?
  languages                     String    @default("[]")
  verification_status           String    @default("unverified")
  institutional_email_verified  Boolean   @default(false)
  subscription_plan_id          String?
  subscription_status           String    @default("inactive")
  subscription_renewal_date     DateTime?
  has_first_year_guarantee      Boolean   @default(false)
  guest_points                  Int       @default(500)
  points_escrow                 Int       @default(0)
  referral_code                 String?   @unique
  referred_by                   String?
  referred_users_verified_count Int       @default(0)
  referral_earnings             Float     @default(0)
  waitlist_position             Int?
  has_sneak_peek                Boolean   @default(false)
  is_founders_circle            Boolean   @default(false)
  notification_preferences      String    @default("{}")
  swap_preferences              String    @default("{}")
  reset_password_token          String?   @unique
  reset_password_expires        DateTime?
  saved_properties              String    @default("[]")
  created_at                    DateTime  @default(now())
  updated_at                    DateTime  @updatedAt
}

model Property {
  id                       String   @id @default(uuid())
  owner_email              String
  title                    String
  description              String?
  property_type            String?
  status                   String   @default("draft")
  is_featured              Boolean  @default(false)
  address                  String?
  city                     String
  country                  String
  host_phone               String?
  handoff_method           String?
  latitude                 Float?
  longitude                Float?
  duty_station             String?
  nearest_duty_station     String?
  distance_to_duty_station String?
  bedrooms                 Int      @default(1)
  bathrooms                Int      @default(1)
  max_guests               Int      @default(2)
  square_meters            Float?
  amenities                String   @default("[]")
  photos                   String   @default("[]")
  images                   String   @default("[]")
  mobility_tags            String   @default("[]")
  security_checklist       String   @default("{}")
  availability             String?
  availability_type        String?
  minimum_stay             Int      @default(1)
  maximum_stay             Int      @default(30)
  available_from           String?
  available_to             String?
  nightly_points           Int      @default(100)
  guest_points_value       Float?
  swap_preference          String?
  swap_types_accepted      String   @default("[\"reciprocal\"]")
  total_swaps              Int      @default(0)
  total_reviews            Int      @default(0)
  average_rating           Float?
  favorites_count          Int      @default(0)
  views_count              Int      @default(0)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt
}

model SwapRequest {
  id                    String    @id @default(uuid())
  requester_email       String
  host_email            String
  property_id           String
  requester_property_id String?
  property_title        String?
  status                String    @default("pending")
  swap_type             String    @default("reciprocal")
  check_in              DateTime?
  check_out             DateTime?
  duration_nights       Int?
  purpose               String?
  party_size            Int       @default(1)
  total_points          Int?
  points_in_escrow      Boolean   @default(false)
  waiver_signed         Boolean   @default(false)
  waiver_signed_at      DateTime?
  insurance_activated   Boolean   @default(false)
  video_call_completed  Boolean   @default(false)
  video_call_id         String?
  counter_check_in      DateTime?
  counter_check_out     DateTime?
  counter_notes         String?
  completed_at          DateTime?
  requester_completed   Boolean   @default(false)
  host_completed        Boolean   @default(false)
  requester_rating      Float?
  host_rating           Float?
  
  // Counter proposal fields
  counter_message       String?

  // Finalization fields
  key_handoff_method        String?
  lockbox_code              String?
  emergency_contact_name    String?
  emergency_contact_phone   String?
  special_instructions      String?
  insurance_certificate_url String?
  finalized_at              DateTime?

  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
}

model Message {
  id              String   @id @default(uuid())
  sender_email    String
  sender_name     String?
  recipient_email String
  swap_request_id String?
  conversation_id String?
  content         String
  is_read         Boolean  @default(false)
  read_at         DateTime?
  message_type    String   @default("text")

  parent_message_id    String?
  thread_count         Int      @default(0)
  deleted_by_sender    Boolean  @default(false)
  deleted_by_recipient Boolean  @default(false)
  deleted_at           DateTime?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model Notification {
  id           String   @id @default(uuid())
  user_email   String
  type         String
  title        String
  message      String
  link         String?
  related_id   String?
  sender_email String?
  sender_name  String?
  is_read      Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model Verification {
  id                String    @id @default(uuid())
  user_id           String?
  user_name         String?
  user_email        String
  verification_type String
  status            String    @default("pending")
  document_url      String?
  document_type     String?
  organization      String?
  staff_grade       String?
  duty_station      String?
  is_email_verified Boolean   @default(false)
  notes             String?
  reviewer_notes    String?
  reviewed_by       String?
  reviewed_at       DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
}

model Review {
  id              String   @id @default(uuid())
  property_id     String
  property_title  String?
  author_email    String
  reviewer_name   String?
  target_email    String?
  swap_request_id String?
  rating          Float
  review_text     String?
  content         String? // Legacy support
  status          String   @default("pending")
  stay_date       DateTime?
  response_from_host String?
  response_date   DateTime?
  helpful_count   Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model VideoCall {
  id               String    @id @default(uuid())
  swap_request_id  String?
  host_id          String?
  host_email       String
  host_name        String?
  guest_id         String?
  guest_email      String
  guest_name       String?
  property_id      String?
  room_id          String?
  room_url         String?
  scheduled_at     DateTime? // Kept for backward compatibility if needed, but we'll use scheduled_time
  scheduled_time   DateTime?
  duration_minutes Int       @default(30)
  status           String    @default("scheduled")
  meeting_completed Boolean   @default(false)
  call_ended_at    DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
}

model SubscriptionPlan {
  id                        String   @id @default(uuid())
  name                      String
  description               String?
  price                     Float
  currency                  String   @default("USD")
  type                      String
  exchanges_per_year        Int?
  property_guarantee_amount Float?
  max_swaps                 Int?
  is_active                 Boolean  @default(true)
  features                  String   @default("[]")
  sort_order                Int      @default(0)
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt
}

model PaymentTransaction {
  id                   String   @id @default(uuid())
  user_email           String
  subscription_plan_id String?
  amount               Float
  currency             String   @default("USD")
  status               String   @default("pending")
  payment_gateway_id   String?
  payment_method       String?
  receipt_url          String?
  transaction_type     String
  metadata             String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
}

model GuestPointTransaction {
  id               String   @id @default(uuid())
  user_email       String
  transaction_type String
  points           Int
  balance_after    Int
  description      String?
  related_id       String?
  metadata         String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
}

model Referral {
  id                     String    @id @default(uuid())
  referrer_email         String
  referred_email         String    @unique
  referred_name          String?
  status                 String    @default("pending")
  referred_user_status   String    @default("invited")
  referrer_reward_status String    @default("no_reward")
  reward_details         String?
  completed_at           DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
}

model ActivityLog {
  id            String   @id @default(uuid())
  activity_type String
  description   String
  location_from String?
  location_to   String?
  is_public     Boolean  @default(false)
  metadata      String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model PlatformSettings {
  id                                     String   @id @default(uuid())
  platform_name                          String   @default("Unswap")
  platform_status                        String   @default("pre_launch")
  founders_waiver_enabled                Boolean  @default(true)
  required_verified_referrals_for_waiver Int      @default(5)
  maintenance_mode                       Boolean  @default(false)
  waitlist_enabled                       Boolean  @default(true)
  max_properties_per_user                Int      @default(3)
  early_bird_discount_pct                Float    @default(50)
  early_bird_slots                       Int      @default(500)
  trust_first_refund_days                Int      @default(30)
  guest_points_per_swap_night            Int      @default(10)
  institutional_email_domains            String?
  public_settings                        String?
  created_at                             DateTime @default(now())
  updated_at                             DateTime @updatedAt
}

model TypingStatus {
  id              String   @id @default(uuid())
  conversation_id String
  user_email      String
  is_typing       Boolean  @default(false)
  updated_at      DateTime @updatedAt
}

model PinnedConversation {
  id              String   @id @default(uuid())
  user_email      String
  conversation_id String
  created_at      DateTime @default(now())
}

model MessageReaction {
  id         String   @id @default(uuid())
  message_id String
  user_email String
  emoji      String
  created_at DateTime @default(now())
}

model WaitlistEntry {
  id                            String    @id @default(uuid())
  email                         String    @unique
  full_name                     String?
  organization                  String?
  waitlist_position             Int?
  referral_code                 String    @unique
  referred_by                   String?   // referral_code of referrer
  referred_users_verified_count Int       @default(0)
  is_verified                   Boolean   @default(true)  // always true: OTP confirmed
  created_at                    DateTime  @default(now())
  updated_at                    DateTime  @updatedAt

  referrals WaitlistReferral[] @relation("ReferrerEntries")
}

model WaitlistReferral {
  id               String        @id @default(uuid())
  referrer_code    String
  referrer         WaitlistEntry @relation("ReferrerEntries", fields: [referrer_code], references: [referral_code])
  referred_email   String        @unique
  referred_name    String?
  completed_at     DateTime?
  created_at       DateTime      @default(now())
}
